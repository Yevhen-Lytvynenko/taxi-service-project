{
  "name": "taxi-service-project",
  "version": "1.0.0",
  "private": true,
  "description": "Strum Taxi Monorepo",
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package",
    "test": "echo \"Error: no test specified\" && exit 1",
    "backend": "npm run dev -w packages/backend",
    "db:generate": "npm --prefix packages/backend run db:generate",
    "db:migrate:dev": "npm run db:migrate -w @taxi/backend",
    "db:migrate:deploy": "npm --prefix packages/backend run db:migrate:deploy",
    "db:seed": "npm run db:seed -w @taxi/backend",
    "gps-sim": "npm run start -w @taxi/gps-simulator",
    "emulation": "npm run gps-sim",
    "admin": "npm run dev -w packages/web-admin",
    "client": "npm run start -w packages/app-client",
    "driver": "npm run start -w packages/app-driver",
    "start:all": "concurrently -n backend,admin,client,driver,gps -c blue,green,magenta,cyan,red \"npm run backend\" \"npm run admin\" \"npm run client\" \"npm run driver\" \"npm run gps-sim\"",
    "clean": "rd /s /q node_modules && npm run clean -w packages/app-client && npm run clean -w packages/backend"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "@types/react": "18.2.79"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.1"
  }
}
